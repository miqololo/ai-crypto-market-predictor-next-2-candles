BINANCE_API_KEY=
BINANCE_API_SECRET=
CHROMA_PERSIST_DIR=./chroma_db

# MongoDB for historical candle storage (fetch_binance_to_mongo.py)
MONGODB_URI=mongodb://localhost:27017

# Hugging Face token (optional). Enables higher rate limits and faster model downloads.
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM API (required). Use Ollama or any OpenAI-compatible API.
# Examples: http://localhost:11434/v1 (Ollama) | https://api.openai.com/v1
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5:7b-coder
